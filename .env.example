# JWT 配置（必填，生产环境必须修改）
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# AI 配置
DEEPSEEK_API_KEY=

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 数据库配置（必填）
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/anticheat?charset=utf8mb4
# SQLite 备选:
# DATABASE_URL=sqlite:///data/orders.db
# DB_PATH=data/orders.db

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 密码加密密钥（必填，生产环境必须修改）
PASSWORD_ENCRYPTION_KEY=

# 验证码服务配置（可选，默认使用内置值）
CAPTCHA_AK=
CAPTCHA_URL=

# 速率限制
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW_SECONDS=60

# 日志级别
LOG_LEVEL=INFO

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173

# 易支付主站配置
EZFPY_MAIN_PID=
EZFPY_MAIN_KEY=
EZFPY_GATEWAY_URL=

# 收款监控 APP 配置
VMQPAY_URL=
VMQPAY_KEY=

# 站点地址
SITE_URL=http://localhost:8000
